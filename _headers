/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; base-uri 'self'; form-action 'self' mailto:; frame-ancestors 'none'

/styles.css
  Cache-Control: public, max-age=14400, must-revalidate

/script.js
  Cache-Control: public, max-age=14400, must-revalidate

/og.svg
  Cache-Control: public, max-age=86400, must-revalidate
